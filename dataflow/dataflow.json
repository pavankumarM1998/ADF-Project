{
	"name": "dataflow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Dynamic_csv",
						"type": "DatasetReference"
					},
					"name": "source"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "Datalake",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "fullname"
				},
				{
					"name": "select"
				}
			],
			"scriptLines": [
				"source(output(",
				"          driver_id as short,",
				"          first_name as string,",
				"          last_name as string,",
				"          phone_number as string,",
				"          vehicle_id as short,",
				"          driver_rating as double,",
				"          city as string,",
				"          last_updated_timestamp as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: true,",
				"     ignoreNoFilesFound: false) ~> source",
				"source derive(Full_Name = concatWS(\" \" ,first_name,last_name)) ~> fullname",
				"fullname select(mapColumn(",
				"          driver_id,",
				"          Full_Name,",
				"          Phone_number = phone_number,",
				"          Vehicle_id = vehicle_id,",
				"          driver_rating,",
				"          city,",
				"          last_updated_timestamp",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select",
				"select sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'sink',",
				"     folderPath: 'Dataflow',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: false,",
				"     upsertable: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}